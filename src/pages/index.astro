---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Links AI" description="Links AI helps businesses implement AI. From simple automations to full AI-powered operations.">
  <section class="hero" slot="hero">
    <h1>We implement AI into your business.</h1>
    <p>
      Whether you need a simple automation or a team of AI agents running
      your operations, we design it, build it, and support it.
    </p>
    <a class="btn" href="/contact">Book an exploratory call</a>
  </section>

  <section class="section">
    <h2>What We Do</h2>
    <div class="grid">
      <div class="card">
        <h3>We start where you are</h3>
        <p>Every business is different. We learn how yours actually runs before recommending anything.</p>
      </div>
      <div class="card">
        <h3>Built around your tools</h3>
        <p>We integrate with the software you already use. No rip-and-replace required.</p>
      </div>
      <div class="card">
        <h3>From simple to advanced</h3>
        <p>Some businesses start with one automation. Others need intelligent agents handling entire workflows. We do both.</p>
      </div>
      <div class="card">
        <h3>We stay involved</h3>
        <p>Implementation is just the beginning. We monitor, improve, and expand the system as your business grows.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Our Process</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">01</span>
        <h3>Discover</h3>
        <p>We learn your business and identify the highest-impact AI opportunities.</p>
      </div>
      <div class="step">
        <span class="step-num">02</span>
        <h3>Design</h3>
        <p>We scope the right solution — whether that's a focused tool or a broader system.</p>
      </div>
      <div class="step">
        <span class="step-num">03</span>
        <h3>Build</h3>
        <p>We implement it inside your real environment and make sure it works.</p>
      </div>
      <div class="step">
        <span class="step-num">04</span>
        <h3>Support</h3>
        <p>We refine, monitor, and expand the system over time.</p>
      </div>
    </div>
  </section>

  <section class="cta-box">
    <h2>Ready to see what AI can do for your business?</h2>
    <p>Tell us about your business. We'll tell you where to start.</p>
    <a class="btn" href="/contact">Request a call</a>
  </section>
</BaseLayout>
