---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Services | Links AI"
  description="Links AI services: free exploratory call, opportunity map, build and launch, ongoing support."
  pageClass="page-services"
>
  <section class="hero" slot="hero">
    <h1>Services</h1>
    <p>
      We offer a clear ladder from exploration to ongoing support.
    </p>
    <a class="btn" href="/contact">Book an exploratory call</a>
  </section>

  <section class="section">
    <h2>What we offer</h2>
    <div class="grid">
      <div class="card">
        <h3>Free exploratory call</h3>
        <p>A no-pressure conversation to understand your business and where AI could help. No commitment.</p>
      </div>
      <div class="card">
        <h3>Opportunity map</h3>
        <p>We map your highest-impact workflows and recommend a focused starting point with clear scope and outcomes.</p>
      </div>
      <div class="card">
        <h3>Build and launch</h3>
        <p>We design and implement the solution inside your real environment and get it running with your team.</p>
      </div>
      <div class="card">
        <h3>Ongoing support</h3>
        <p>We monitor, refine, and expand the system over time so you get lasting value.</p>
      </div>
    </div>
  </section>

  <section class="cta-box">
    <h2>Start with a free call</h2>
    <p>Tell us about your business. We'll tell you where to start.</p>
    <a class="btn" href="/contact">Request a call</a>
  </section>
</BaseLayout>
