---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="How It Works | Links AI"
  description="How Links AI works: free exploratory call, opportunity map, build and launch, ongoing improvement."
  pageClass="page-how-it-works"
>
  <section class="hero" slot="hero">
    <h1>How it works</h1>
    <p>
      A simple process from first conversation to ongoing support.
    </p>
    <a class="btn" href="/contact">Book an exploratory call</a>
  </section>

  <section class="section">
    <h2>Our process</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">01</span>
        <h3>Free exploratory call</h3>
        <p>We learn about your business, your goals, and where AI could have the biggest impact.</p>
      </div>
      <div class="step">
        <span class="step-num">02</span>
        <h3>Opportunity map</h3>
        <p>We identify the highest-value workflows and scope a clear path forward.</p>
      </div>
      <div class="step">
        <span class="step-num">03</span>
        <h3>Build and launch</h3>
        <p>We implement the solution in your environment and make sure it works for your team.</p>
      </div>
      <div class="step">
        <span class="step-num">04</span>
        <h3>Ongoing improvement</h3>
        <p>We monitor, refine, and expand the system as your needs evolve.</p>
      </div>
    </div>
  </section>

  <section class="cta-box">
    <h2>Ready to start?</h2>
    <p>Book a free exploratory call. No commitment required.</p>
    <a class="btn" href="/contact">Get in touch</a>
  </section>
</BaseLayout>
